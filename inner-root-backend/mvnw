#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper Shell Script for Linux/Railway
# ----------------------------------------------------------------------------

export MAVEN_PROJECTBASEDIR=$(pwd)
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

# Download wrapper if missing (matching the cmd script behavior)
if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    mkdir -p "$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
    curl -sfL 'https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar' -o "$WRAPPER_JAR"
fi

if [ -z "$JAVA_HOME" ]; then
    JAVA_EXE="java"
else
    JAVA_EXE="$JAVA_HOME/bin/java"
fi

exec "$JAVA_EXE" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
